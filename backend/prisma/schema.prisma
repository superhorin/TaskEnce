// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider    = "prisma-client-js"
}

generator markdown {
  provider = "prisma-markdown"
  output   = "../../docs/ERD.md"
  title    = "ER図"
}

datasource db {
  provider  = "postgresql"
}

// ==========================================
// Enums
// ==========================================

enum Difficulty {
  TRIVIAL
  SIMPLE
  CHALLENGING
  HARD
  EPIC
}

enum Duration {
  BURST
  QUICK
  STANDARD
  LONG
  MARATHON
}

enum Priority {
  MINOR
  NORMAL
  IMPORTANT
  MAJOR
  CRITICAL
}

enum ThreadStatus {
  OPEN
  DONE
}

enum  TeamRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum MembershipStatus {
  INVITED
  ACTIVE
  BLOCKED
  DECLINED
}

enum TaskType {
  DEFAULT
  REPLY
}

enum ActionType {
  CREATED
  PROGRESSED
  PASSED
  COMPLETED
  CANCELED
}

// ==========================================
// Models
// ==========================================

model User {
  id    String  @id @default(uuid())
  name  String

  email     String  @unique
  password  String

  iconUrl String?

  level Int @default(0)
  exp   Int @default(0)

  createdTasks      Task[]  @relation("TaskAuthor")
  assignedTasks     Task[]  @relation("TaskAssignee")
  contributedTasks  Task[]  @relation("TaskContributors")

  memberships   Membership[]  @relation("UserMemberships")
  invitedMember Membership[]  @relation("InviterMemberships")

  chatThreads ChatThread[]  @relation("ThreadMembers")
  messages  Message[]

  actionPerformed TaskAction[]  @relation("ActionActor")
  actionReceived  TaskAction[]  @relation("ActionPassedTo")

  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())
}

model Team {
  id    String  @id @default(uuid())
  name  String

  iconUrl String?

  level Int @default(0)
  exp   Int @default(0)

  tasks       Task[]
  members     Membership[]
  chatThreads ChatThread[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?

  type        TaskType  @default(DEFAULT)

  difficulty  Difficulty  @default(SIMPLE)
  duration    Duration    @default(STANDARD)
  priority    Priority    @default(NORMAL)

  progress    Int @default(0)

  authorId    String
  author      User      @relation("TaskAuthor", fields: [authorId], references: [id])

  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])

  contributors User[]   @relation("TaskContributors")

  chatThreadId  String?
  chatThread    ChatThread? @relation(fields: [chatThreadId], references: [id])

  teamId      String?
  team        Team?     @relation(fields: [teamId], references: [id])

  actions  TaskAction[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  achievedAt  DateTime?
  dueDate     DateTime?
}

model TaskAction {
  id  String  @id @default(uuid())

  taskId  String
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  actorId String
  actor   User    @relation("ActionActor", fields: [actorId], references: [id])

  actionType  ActionType

  message  String?

  passedToId  String?
  passedTo    User?   @relation("ActionPassedTo", fields: [passedToId], references: [id])

  createdAt DateTime  @default(now())
}

model ChatThread {
  id      String        @id @default(uuid())
  title   String
  status    ThreadStatus  @default(OPEN)
  priority  Priority    @default(NORMAL)

  members   User[]  @relation("ThreadMembers")
  messages  Message[]

  teamId    String?
  team      Team?   @relation(fields: [teamId], references: [id])

  tasks     Task[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id    String  @id @default(uuid())
  text  String

  priority  Priority    @default(NORMAL)

  senderId  String
  sender    User  @relation(fields: [senderId], references: [id])

  chatThreadId  String
  chatThread    ChatThread  @relation(fields: [chatThreadId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
}

model Membership {
  id  String  @id @default(uuid())

  role    TeamRole  @default(MEMBER)
  status  MembershipStatus  @default(INVITED)

  nickname  String?
  position  String?
  isMuted   Boolean @default(false)

  teamExp   Int @default(0)
  teamLevel Int @default(0)

  userId  String
  user    User  @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)

  teamId  String
  team    Team  @relation(fields: [teamId], references: [id])

  inviterId String?
  inviter   User?  @relation("InviterMemberships", fields: [inviterId], references: [id])

  createdAt DateTime  @default(now())
  joinedAt  DateTime?
  updatedAt DateTime  @updatedAt

  @@unique([userId, teamId])
}
