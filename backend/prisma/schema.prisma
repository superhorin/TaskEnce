// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider    = "prisma-client-js"
}

generator markdown {
  provider = "prisma-markdown"
  output   = "../../docs/ERD.md"
  title    = "ER図"
}

datasource db {
  provider  = "postgresql"
}

enum Difficulty {
  TRIVIAL
  SIMPLE
  CHALLENGING
  HARD
  EPIC
}

enum Duration {
  BURST
  QUICK
  STANDARD
  LONG
  MARATHON
}

enum Priority {
  MINOR
  NORMAL
  IMPORTANT
  MAJOR
  CRITICAL
}

enum ThreadStatus {
  OPEN
  DONE
}

enum  TeamRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum MembershipStatus {
  INVITED
  ACTIVE
  BLOCKED
  DECLINED
}

model User {
  id    String  @id @default(uuid())
  name  String

  email     String  @unique
  password  String

  iconUrl String?

  level Int @default(0)
  exp   Int @default(0)

  createdTasks      Task[]  @relation("TaskAuthor")
  assignedTasks     Task[]  @relation("TaskAssignee")
  contributedTasks  Task[]  @relation("TaskContributors")

  memberships   Membership[]  @relation("UserMemberships")
  invitedMember Membership[]  @relation("InviterMemberships")

  chatThreads ChatThread[]  @relation("ThreadMembers")

  messages  Message[]

  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())
}

model Team {
  id    String  @id @default(uuid())
  name  String

  iconUrl String?

  level Int @default(0)
  exp   Int @default(0)

  tasks Task[]

  members Membership[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?

  difficulty  Difficulty  @default(SIMPLE)
  duration    Duration    @default(STANDARD)
  priority    Priority    @default(NORMAL)

  progress    Int @default(0)

  authorId    String
  author      User      @relation("TaskAuthor", fields: [authorId], references: [id])

  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])

  contributors User[]   @relation("TaskContributors")

  parentTaskId  String?
  parentTask    Task?   @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks      Task[]  @relation("SubTasks")

  messages Message[] @relation("TaskMessages")

  sourceMessageId String?
  sourceMessage   Message? @relation("TaskFromMessage", fields: [sourceMessageId], references: [id])

  teamId      String?
  team        Team?     @relation(fields: [teamId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  achievedAt  DateTime?
  dueDate     DateTime?
}

model ChatThread {
  id      String        @id @default(uuid())
  title   String
  status    ThreadStatus  @default(OPEN)
  priority  Priority    @default(NORMAL)

  members   User[]  @relation("ThreadMembers")
  messages  Message[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id    String  @id @default(uuid())
  text  String

  senderId  String
  sender    User  @relation(fields: [senderId], references: [id])

  threadId  String?
  thread    ChatThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)

  taskId  String?
  task    Task? @relation("TaskMessages", fields: [taskId], references: [id], onDelete: Cascade)

  derivedTasks  Task[]  @relation("TaskFromMessage")

  createdAt DateTime  @default(now())
}

model Membership {
  id  String  @id @default(uuid())

  role    TeamRole  @default(MEMBER)
  status  MembershipStatus  @default(INVITED)

  nickname  String?
  position  String?
  isMuted   Boolean @default(false)

  teamExp   Int @default(0)
  teamLevel Int @default(0)

  userId  String
  user    User  @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)

  teamId  String
  team    Team  @relation(fields: [teamId], references: [id])

  inviterId String?
  inviter   User?  @relation("InviterMemberships", fields: [inviterId], references: [id])

  createdAt DateTime  @default(now())
  joinedAt  DateTime?
  updatedAt DateTime  @updatedAt

  @@unique([userId, teamId])
}
